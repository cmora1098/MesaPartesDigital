@page "/consulta-expediente"
@rendermode InteractiveServer

<div class="consulta-container">

    <div class="consulta-card">

        <h2>Consulta de Expediente</h2>
        <p class="consulta-subtitle">
            Ingrese los datos para consultar el estado de su trámite
        </p>

        <div class="consulta-form">

            <div class="form-group">
                <label>Número de expediente</label>
                <input type="text" placeholder="Ej: 2024-000123" />
            </div>

            <div class="form-group">
                <label>DNI / RUC</label>
                <input type="text" placeholder="Ingrese su documento" />
            </div>

            <button class="btn-consultar">
                Consultar
            </button>

        </div>

    </div>

</div>