@page "/inicio/juridica"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms

<div class="ux-bg">

    <div class="ux-container">

        <!-- PROGRESS -->
        <div class="ux-progress">
            <div class="step @(paso >= 1 ? "active" : "")">Datos</div>
            <div class="step @(paso >= 2 ? "active" : "")">Verificación</div>
            <div class="step @(paso >= 3 ? "active" : "")">Documento</div>
            <div class="step @(paso >= 4 ? "active" : "")">Final</div>
        </div>

        <!-- CARD -->
        <div class="ux-card-full">

            <!-- PASO 1 -->
            @if (paso == 1)
            {
                <h2>
                    Datos de la Persona Jurídica (Pública/Privada)
                </h2>

                <p class="ux-description">
                    Canal virtual para presentar documentos sin acudir presencialmente.
                </p>

                <!-- EMPRESA -->
                <div class="ux-grid-3">

                    <div class="ux-field">
                        <label>Nro. RUC</label>
                        <input class="ux-input" @bind="ruc" maxlength="11" />
                    </div>

                    <div class="ux-field" style="justify-content:end;">
                        <button class="ux-button" @onclick="ValidarRuc">Validar</button>
                    </div>

                </div>

                <div class="ux-field">
                    <label>Razón Social</label>
                    <input class="ux-input" @bind="razonSocial" readonly />
                </div>

                <div class="ux-field">
                    <label>Dirección</label>
                    <input class="ux-input" @bind="direccion" />
                </div>

                <hr />

                <!-- REPRESENTANTE -->
                <h3>Datos del Representante</h3>

                <div class="ux-grid-3">

                    <div class="ux-field">
                        <label>Tipo Documento</label>
                        <select class="ux-input" @bind="tipoDoc">
                            <option value="01">DNI</option>
                            <option value="02">Carné Extranjería</option>
                            <option value="03">Pasaporte</option>
                            <option value="04">Otros</option>
                        </select>
                    </div>

                    <div class="ux-field">
                        <label>Nro Documento</label>
                        <input class="ux-input" @bind="numDoc" />
                    </div>

                </div>

                <div class="ux-grid">
                    <div class="ux-field">
                        <label>Nombres</label>
                        <input class="ux-input" @bind="nombres" />
                    </div>

                    <div class="ux-field">
                        <label>Apellidos</label>
                        <input class="ux-input" @bind="apellidos" />
                    </div>
                </div>

                <div class="ux-grid">
                    <div class="ux-field">
                        <label>Correo</label>
                        <input class="ux-input" @bind="correo" />
                    </div>

                    <div class="ux-field">
                        <label>Teléfono</label>
                        <input class="ux-input" @bind="telefono" />
                    </div>
                </div>

                <div class="ux-field">
                    <label>Cargo</label>
                    <input class="ux-input" @bind="cargo" />
                </div>

                <div class="ux-actions">
                    <div></div>
                    <button class="ux-button" @onclick="Siguiente">Siguiente →</button>
                </div>
            }

            <!-- PASO 2 -->
            @if (paso == 2)
            {
                <h2>Verificación</h2>

                <p class="ux-description">
                    Ingresa el código enviado a tu correo electrónico.
                </p>

                <input class="ux-input" @bind="codigo" maxlength="6" placeholder="Código de verificación" />

                <div class="ux-actions">
                    <button class="ux-button-outline" @onclick="Anterior">← Anterior</button>
                    <button class="ux-button" @onclick="Siguiente">Siguiente →</button>
                </div>
            }

            <!-- PASO 3 -->
            @if (paso == 3)
            {
                <h2>Documento</h2>

                <div class="ux-grid">
                    <select class="ux-input" @bind="tipoDocumento">
                        <option>OFICIO</option>
                        <option>CARTA</option>
                        <option>SOLICITUD</option>
                        <option>OTROS</option>
                    </select>

                    <input class="ux-input" placeholder="Nro documento" @bind="numDocumento" />
                </div>

                <!-- ARCHIVO -->
                <p class="ux-help">(Solo PDF - Máx. 25MB)</p>

                <InputFile OnChange="OnFileSelected" accept=".pdf,application/pdf" class="ux-input" />

                @if (archivo != null)
                {
                    <p class="ux-success">@archivo.Name</p>
                }
                else
                {
                    <p class="ux-muted">Sin archivo seleccionado</p>
                }

                @if (!string.IsNullOrEmpty(error))
                {
                    <p class="ux-error">@error</p>
                }

                <div class="ux-actions">
                    <button class="ux-button-outline" @onclick="Anterior">← Anterior</button>
                    <button class="ux-button" @onclick="Siguiente">Confirmar →</button>
                </div>
            }

            <!-- PASO 4 -->
            @if (paso == 4)
            {
                <div class="ux-final">
                    <div class="ux-success-icon">✔</div>

                    <h2>Trámite concluido</h2>
                    <p>Tu solicitud fue registrada correctamente.</p>

                    <button class="ux-button" @onclick="Finish">Aceptar</button>

                </div>
            }

        </div>
    </div>
</div>

@code {
    private int paso = 1;

    // EMPRESA
    private string ruc;
    private string razonSocial;
    private string direccion;

    // REPRESENTANTE
    private string tipoDoc = "01";
    private string numDoc;
    private string nombres;
    private string apellidos;
    private string correo;
    private string telefono;
    private string cargo;

    // VERIFICACIÓN
    private string codigo;

    // DOCUMENTO
    private string tipoDocumento;
    private string numDocumento;
    private IBrowserFile? archivo;
    private string error = "";

    [Inject] NavigationManager Nav { get; set; }
    void Finish()
    {
        Nav.NavigateTo("/");
    }
    private void Siguiente()
    {
        if (paso < 4) paso++;
    }

    private void Anterior()
    {
        if (paso > 1) paso--;
    }

    private void ValidarRuc()
    {
        // Simulación
        razonSocial = "EMPRESA DEMO S.A.C.";
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file.ContentType != "application/pdf" &&
            !file.Name.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
        {
            error = "Solo se permiten archivos PDF.";
            archivo = null;
            return;
        }

        if (file.Size > 25 * 1024 * 1024)
        {
            error = "El archivo supera los 25MB.";
            archivo = null;
            return;
        }

        error = "";
        archivo = file;
    }
}