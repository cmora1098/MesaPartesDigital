@page "/inicio/juridica"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms

<div class="ux-bg">

    <div class="ux-container">

        <div class="ux-header">
            <div class="ux-badge-top">Mesa de Partes Digital</div>
            <h1>Persona Jurídica</h1>
            <p class="ux-description">
                Completa todos los campos para registrar tu documento.
            </p>
        </div>

        <div class="ux-card-form">

            <h2>I. DATOS DE LA EMPRESA</h2>

            <div class="ux-grid-form">

                <div class="ux-field">
                    <label>RUC *</label>
                    <div class="ux-input-group">
                        <input @bind="rucInputValue" placeholder="Ingrese RUC" />
                        <button type="button" class="ux-button" @onclick="ValidarRuc">
                            Validar
                        </button>
                    </div>
                </div>

                <div class="ux-field">
                    <label>Razón Social *</label>
                    <input @bind="razonSocialValue" readonly class="ux-readonly" placeholder="Se autocompleta al validar" />
                </div>

                <div class="ux-field full">
                    <label>Dirección *</label>
                    <input />
                </div>

                <div class="ux-field">
                    <label>Correo *</label>
                    <input type="email" />
                </div>

                <div class="ux-field">
                    <label>Teléfono *</label>
                    <input />
                </div>

            </div>

        </div>

        <div class="ux-card-form">

            <h2>II. DATOS DEL REPRESENTANTE LEGAL</h2>

            <div class="ux-grid-form">

                <div class="ux-field">
                    <label>Tipo de Documento *</label>
                    <select @bind="repTipoDocumento" @bind:after="OnRepTipoDocumentoChange">
                        <option value="DNI">DNI</option>
                        <option value="CE">Carnet de Extranjería</option>
                        <option value="PAS">Pasaporte</option>
                    </select>
                </div>

                <div class="ux-field">
                    <label>Nro. Documento *</label>
                    @if (repTipoDocumento == "DNI")
                    {
                        <div class="ux-input-group">
                            <input @bind="repNumeroDocumento" maxlength="8" placeholder="Ingrese DNI" />
                            <button type="button" class="ux-button" @onclick="ValidarRepDni">
                                Validar
                            </button>
                        </div>
                    }
                    else
                    {
                        <input @bind="repNumeroDocumento" maxlength="20" placeholder="Ingrese Nro. Documento" />
                    }

                    @if (!string.IsNullOrEmpty(repErrorDocumento))
                    {
                        <span class="ux-error">@repErrorDocumento</span>
                    }
                </div>

                <div class="ux-field">
                    <label>Apellido Paterno *</label>
                    <input @bind="repApellidoPaterno"
                           readonly="@repCamposBloqueados"
                           class="@(repCamposBloqueados ? "ux-readonly" : "")"
                           placeholder="@(repCamposBloqueados ? "Se autocompleta al validar" : "")" />
                </div>

                <div class="ux-field">
                    <label>Apellido Materno *</label>
                    <input @bind="repApellidoMaterno"
                           readonly="@repCamposBloqueados"
                           class="@(repCamposBloqueados ? "ux-readonly" : "")"
                           placeholder="@(repCamposBloqueados ? "Se autocompleta al validar" : "")" />
                </div>

                <div class="ux-field">
                    <label>Nombres *</label>
                    <input @bind="repNombres"
                           readonly="@repCamposBloqueados"
                           class="@(repCamposBloqueados ? "ux-readonly" : "")"
                           placeholder="@(repCamposBloqueados ? "Se autocompleta al validar" : "")" />
                </div>

                <div class="ux-field">
                    <label>Teléfono *</label>
                    <input @bind="repTelefono" placeholder="Ej: 999888777" />
                </div>

                <div class="ux-field">
                    <label>Correo *</label>
                    <input type="email" @bind="repCorreo" placeholder="ejemplo@correo.com" />
                </div>

            </div>
        </div>

        <div class="ux-card-form">

            <h2>III. DATOS DEL DOCUMENTO</h2>

            <div class="ux-grid-form">

                <div class="ux-field">
                    <label>Tipo de Documento *</label>
                    <select>
                        <option>--SELECCIONAR--</option>
                        <option>Informe</option>
                        <option>Memo</option>
                        <option>Carta</option>
                        <option>Oficio</option>
                        <option>Resoluciones</option>
                        <option>Otros</option>
                    </select>
                </div>

                <div class="ux-field">
                    <label>Nro Documento *</label>
                    <input />
                </div>

                <div class="ux-field">
                    <label>Folio *</label>
                    <input />
                </div>

                <div class="ux-field">
                    <label>Fecha *</label>
                    <input type="date" />
                </div>

                <div class="ux-field full">
                    <label>Sumilla *</label>
                    <textarea maxlength="255"></textarea>
                </div>

                <div class="ux-field full">
                    <label>Referencia</label>
                    <input />
                </div>

            </div>

        </div>

        <div class="ux-card-form">

            <h2>
                Documento adjunto
            </h2>

            <InputFile OnChange="OnFileSelected" accept=".pdf" class="ux-file" />

            @if (archivo != null)
            {
                <p class="ux-success">@archivo.Name</p>

                <div class="ux-pdf-preview">
                    <iframe src="@pdfPreviewUrl"></iframe>
                </div>
            }

            @if (!string.IsNullOrEmpty(error))
            {
                <p class="ux-error">@error</p>
            }

            <div class="mt-3">
                <button type="button" class="ux-button-outline" @onclick="ToggleUrl">
                    + Agregar URL
                </button>
            </div>

            @if (mostrarUrl)
            {
                <input class="ux-input-url" @bind="urlArchivo" placeholder="https://..." />
            }

        </div>

        <div class="ux-card-form">

            <h2>Anexos</h2>

            <p class="ux-help">
                (Peso máximo de cada archivo: 20MB)<br />
                (Formatos permitidos: PDF, DOCX, XLSX, PPT, JPG, PNG y ZIP)<br />
                (Número máximo de anexos: 10)
            </p>

            <InputFile OnChange="HandleFilesSelected" multiple class="ux-file" />

            <div class="ux-table-wrapper">

                <table class="ux-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Tipo</th>
                            <th>Tamaño</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (archivos.Any())
                        {
                            @foreach (var item in archivos)
                            {
                                <tr>
                                    <td>@item.Nombre</td>
                                    <td>@item.Tipo</td>
                                    <td>@item.Tamano</td>
                                    <td>
                                        <button class="btn-delete" type="button"
                                                @onclick="() => EliminarArchivo(item)">
                                            Eliminar
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="ux-empty">
                                    Sin archivos
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>


            <hr class="ux-divider" />

            <div class="ux-nota">
                <strong>Nota:</strong><br />
                El número del expediente de la presente solicitud será notificado al correo electrónico consignado en el presente formulario.
            </div>

            <hr class="ux-divider" />

            <div class="ux-actions-right">
                <button class="ux-button" @onclick="Finalizar">
                    Enviar solicitud
                </button>
            </div>

        </div>

    </div>

</div>

@code {

    [Inject] NavigationManager Nav { get; set; }

    // Variables para el RUC y Razón Social
    private string rucInputValue = "";
    private string razonSocialValue = "";

    private IBrowserFile? archivo;
    private string? pdfPreviewUrl;

    private List<ArchivoAdjunto> archivos = new();

    private string error = "";
    private string urlArchivo = "";
    private bool mostrarUrl = false;

    // Método simulado para validar el RUC (Aquí puedes conectar tu API de SUNAT o backend)
    private async Task ValidarRuc()
    {
        if (string.IsNullOrWhiteSpace(rucInputValue))
        {
            razonSocialValue = "RUC Inválido";
            return;
        }

        // Simulación de retraso de red / API
        razonSocialValue = "Buscando...";
        await Task.Delay(800);

        // Ejemplo de respuesta simulada
        if (rucInputValue == "20123456789")
        {
            razonSocialValue = "EMPRESA DE PRUEBA S.A.C.";
        }
        else
        {
            razonSocialValue = $"EMPRESA ASOCIADA AL RUC {rucInputValue}";
        }
    }

    private void Finalizar()
    {
        Nav.NavigateTo("/");
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        error = "";
        archivo = e.File;

        if (archivo == null)
            return;

        if (archivo.ContentType != "application/pdf")
        {
            error = "Solo PDF.";
            archivo = null;
            pdfPreviewUrl = null;
            return;
        }

        var stream = archivo.OpenReadStream(25 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        var base64 = Convert.ToBase64String(ms.ToArray());
        pdfPreviewUrl = $"data:application/pdf;base64,{base64}";
    }

    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles(10))
        {
            if (file.Size > 20 * 1024 * 1024)
                continue;

            var ext = Path.GetExtension(file.Name).ToLower();

            var permitidos = new[] { ".pdf", ".docx", ".xlsx", ".ppt", ".jpg", ".png", ".zip" };

            if (!permitidos.Contains(ext))
                continue;

            archivos.Add(new ArchivoAdjunto
            {
                Nombre = file.Name,
                Tipo = ext,
                Tamano = $"{file.Size / 1024} KB"
            });
        }
    }

    private void EliminarArchivo(ArchivoAdjunto archivo)
    {
        archivos.Remove(archivo);
    }

    private void ToggleUrl()
    {
        mostrarUrl = !mostrarUrl;
    }

    public class ArchivoAdjunto
    {
        public string Nombre { get; set; }
        public string Tipo { get; set; }
        public string Tamano { get; set; }
    }

 
    // Variables para el Representante Legal
    private string repTipoDocumento = "DNI";
    private string repNumeroDocumento = "";
    private string repErrorDocumento = "";
    private string repApellidoPaterno = "";
    private string repApellidoMaterno = "";
    private string repNombres = "";
    private string repTelefono = "";
    private string repCorreo = "";

    // CAMBIO AQUÍ: Inicia en true porque el formulario por defecto selecciona "DNI"
    private bool repCamposBloqueados = true;

    private void OnRepTipoDocumentoChange()
    {
        repNumeroDocumento = "";
        repErrorDocumento = "";
        repApellidoPaterno = "";
        repApellidoMaterno = "";
        repNombres = "";

        // Si es DNI vuelve a bloquearse (true), si es CE o PAS se desbloquea (false)
        repCamposBloqueados = (repTipoDocumento == "DNI");
    }

    private async Task ValidarRepDni()
    {
        repErrorDocumento = "";

        if (string.IsNullOrWhiteSpace(repNumeroDocumento) || repNumeroDocumento.Length != 8)
        {
            repErrorDocumento = "El DNI debe tener 8 dígitos.";
            return;
        }

        repNombres = "Buscando...";
        repApellidoPaterno = "...";
        repApellidoMaterno = "...";

        await Task.Delay(900);

        if (repNumeroDocumento == "44445555")
        {
            repApellidoPaterno = "PÉREZ";
            repApellidoMaterno = "GARCÍA";
            repNombres = "JUAN CARLOS";
        }
        else
        {
            repApellidoPaterno = "MENDOZA";
            repApellidoMaterno = "CASTRO";
            repNombres = "MARÍA ELENA";
        }
    }


}