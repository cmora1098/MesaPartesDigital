@page "/inicio/juridica"
@rendermode InteractiveServer

<div class="ux-bg">

    <div class="ux-container">

        <!-- PROGRESS (mejor uso del existente) -->
        <div class="ux-progress">
            <div class="step @(paso >= 1 ? "active" : "")">Datos</div>
            <div class="step @(paso >= 2 ? "active" : "")">Verificación</div>
            <div class="step @(paso >= 3 ? "active" : "")">Documento</div>
            <div class="step @(paso >= 4 ? "active" : "")">Final</div>
        </div>

        <!-- CARD -->
        <div class="ux-card-full">

            @if (paso == 1)
            {
                <h2>Datos de la Persona Jurídica</h2>

                <p class="ux-description">
                    Canal virtual para presentar documentos sin acudir presencialmente.
                </p>

                <label>Nro. RUC</label>
                <div class="ux-row">
                    <input class="ux-input" @bind="ruc" maxlength="11" />
                    <button class="ux-button" @onclick="ValidarRuc">Validar</button>
                </div>

                <label>Razón Social</label>
                <input class="ux-input" @bind="razonSocial" readonly />

                <label>Dirección</label>
                <input class="ux-input" @bind="direccion" />

                <hr />

                <h3>Representante</h3>

                <select class="ux-input" @bind="tipoDoc">
                    <option value="01">DNI</option>
                    <option value="02">Carné Extranjería</option>
                    <option value="03">Pasaporte</option>
                    <option value="04">Otros</option>
                </select>

                <input class="ux-input" placeholder="Número documento" @bind="numDoc" />
                <input class="ux-input" placeholder="Nombres" @bind="nombres" />
                <input class="ux-input" placeholder="Apellidos" @bind="apellidos" />
                <input class="ux-input" placeholder="Correo" @bind="correo" />
                <input class="ux-input" placeholder="Teléfono" @bind="telefono" />
                <input class="ux-input" placeholder="Cargo" @bind="cargo" />

                <div class="ux-actions">
                    <button class="ux-button" @onclick="Siguiente">Siguiente →</button>
                </div>
            }

            @if (paso == 2)
            {
                <h2>Verificación</h2>

                <p class="ux-description">
                    Ingresa el código enviado a tu correo electrónico.
                </p>

                <input class="ux-input" @bind="codigo" maxlength="6" />

                <div class="ux-actions">
                    <button class="ux-button" @onclick="Anterior">← Anterior</button>
                    <button class="ux-button" @onclick="Siguiente">Siguiente →</button>
                </div>
            }

            @if (paso == 3)
            {
                <h2>Documento</h2>

                <select class="ux-input" @bind="tipoDocumento">
                    <option>OFICIO</option>
                    <option>CARTA</option>
                    <option>SOLICITUD</option>
                    <option>OTROS</option>
                </select>

                <input class="ux-input" placeholder="Nro documento" @bind="numDocumento" />
                <input type="file" class="ux-input" />

                <div class="ux-actions">
                    <button class="ux-button" @onclick="Anterior">← Anterior</button>
                    <button class="ux-button" @onclick="Siguiente">Confirmar →</button>
                </div>
            }

            @if (paso == 4)
            {
                <div style="text-align:center">

                    <h2>Trámite concluido</h2>

                    <p class="ux-description">
                        Su solicitud ha sido registrada correctamente.
                    </p>

                    <button class="ux-button">Aceptar</button>

                </div>
            }

        </div>

    </div>

</div>

@code {
    private int paso = 1;

    private string ruc;
    private string razonSocial;
    private string direccion;

    private string tipoDoc;
    private string numDoc;
    private string nombres;
    private string apellidos;
    private string correo;
    private string telefono;
    private string cargo;

    private string codigo;

    private string tipoDocumento;
    private string numDocumento;

    private void Siguiente()
    {
        if (paso < 4) paso++;
    }

    private void Anterior()
    {
        if (paso > 1) paso--;
    }

    private void ValidarRuc()
    {
        razonSocial = "EMPRESA DEMO S.A.C.";
    }
}