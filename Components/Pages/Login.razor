@page "/login"
@layout EmptyLayout
@rendermode InteractiveServer
@inject NavigationManager Nav

<div class="login-wrapper">

    <aside class="login-left">
        <div class="login-left-content">
            <img src="img/logomax_agrorural.png" alt="Logo Agro Rural" class="login-logo" />

            <h2>Bienvenido a la Plataforma de<br /><strong>Mesa de Partes Digital</strong></h2>

            <p>
                Esta entidad pone a su disposición la Mesa de Partes Digital, un canal diseñado para brindar mayor agilidad, eficiencia y accesibilidad a sus trámites administrativos.
            </p>

            <p>
                En cumplimiento con la Ley N° 31465 (que modifica la Ley N° 27444 del Procedimiento Administrativo General), nuestra plataforma se encuentra habilitada para la presentación de documentos las veinticuatro (24) horas del día, los siete (7) días de la semana.
            </p>

            <div class="alerta-box">
                <span class="alerta-icon">⚠️</span>
                <div class="alerta-text">
                    <strong>Nota importante sobre su recepción:</strong><br />
                    El envío del documento no genera su aceptación automática. La recepción formal será validada únicamente mediante la constancia de ingreso enviada a su correo registrado.
                </div>
            </div>

            <footer class="dev-footer">
                Desarrollado por la Sub Unidad de Tecnologías de la Información.
            </footer>
        </div>
    </aside>

    <main class="login-right">
        <div class="login-container-form">

            <img src="img/logomax_agrorural.png" alt="Logo Agro Rural" class="login-logo-mobile" />

            <div class="login-box">
                <h3>Acceso al Sistema</h3>
                <p class="login-subtitle">Ingrese sus credenciales para continuar</p>

                <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                    <div class="input-group">
                        <label for="documento">Número de Documento</label>
                        <input id="documento" type="text" @bind-value="loginModel.Documento" placeholder="Ej. 45678912" required />
                    </div>

                    <div class="input-group">
                        <label for="password">Contraseña</label>
                        <input id="password" type="password" @bind-value="loginModel.Password" placeholder="••••••••" required />
                    </div>

                    <button type="submit" class="btn-login">
                        Ingresar de forma segura
                    </button>
                </EditForm>

                <div class="login-actions-secondary">
                    <button type="button" class="btn-link" @onclick="IrAGenerarClave">Generar clave</button>
                    <span class="divider">|</span>
                    <button type="button" class="btn-link" @onclick="IrARecuperar">¿Olvidó su contraseña?</button>
                </div>
            </div>

            <section class="soporte-box" aria-label="Soporte Técnico">
                <h4>Soporte y Consultas</h4>
                <p>📞 (01) 2058030 <span class="anexo">Anexo 0105</span></p>
                <p>🕒 Lunes a Viernes de 8:30 a. m. a 4:30 p. m.</p>
            </section>
        </div>
    </main>

</div>

@code {
    private LoginModel loginModel = new();

    private void HandleLogin()
    {
        // Aquí puedes agregar la lógica de autenticación real
        Nav.NavigateTo("/dashboard");
    }

    private void IrAGenerarClave() => Nav.NavigateTo("/generar-clave");
    private void IrARecuperar() => Nav.NavigateTo("/recuperar-password");

    public class LoginModel
    {
        public string Documento { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}